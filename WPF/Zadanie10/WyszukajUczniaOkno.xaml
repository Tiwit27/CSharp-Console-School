<Window x:Class="BazyDanych.WyszukajUczniaOkno"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BazyDanych"
        mc:Ignorable="d"
        Title="WyszukajUczniaOkno" Height="450" Width="800">
    <WrapPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Wyszukaj ucznia o nazwisku: " FontSize="50"/>
            <TextBox Name="wyszukaj_id" Width="80" Height="80" FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
        </WrapPanel>

        <Button Name="wyszukajBtn" Width="200" Height="50" Content="Wyszukaj" FontSize="30" FontWeight="Bold" Click="wyszukajBtn_Click"/>
        <DataGrid Name="dataGrid" AutoGenerateColumns="True" Height="200" Background="Beige" FontSize="15"/>
    </WrapPanel>
</Window>
