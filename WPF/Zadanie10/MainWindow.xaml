<Window x:Class="BazyDanych.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BazyDanych"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Button Name="dodajuczniaokno" Content="Dodaj ucznia do bazy" Width="500" Margin="0, 20, 0, 20" FontSize="25" FontWeight="Bold" Click="dodajuczniaokno_Click"/>
        <Button Name="wyswietlbazeokno" Content="Wyświetl bazę uczniów"  Width="500" Margin="0, 20, 0, 20" FontSize="25" FontWeight="Bold" Click="wyswietlbazeokno_Click"/>
        <Button Name="usunuczniaokno" Content="Usuń ucznia z bazy"  Width="500" Margin="0, 20, 0, 20" FontSize="25" FontWeight="Bold" Click="usunuczniaokno_Click"/>
        <Button Name="wyszukajuczniaokno" Content="Wyszukaj ucznia z bazy"  Width="500" Margin="0, 20, 0, 20" FontSize="25" FontWeight="Bold" Click="wyszukajuczniaokno_Click"/>
    </StackPanel>
</Window>
