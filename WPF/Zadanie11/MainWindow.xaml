<Window x:Class="Zadanie11.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Zadanie11"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="600">
    <StackPanel Orientation="Vertical">
        <TextBlock Text="Układanka" FontSize="60" HorizontalAlignment="Center"/>
        <TextBlock Text="Czas:" FontSize="50" HorizontalAlignment="Center" Name="timer"/>
        <TextBlock Text="" FontSize="25" HorizontalAlignment="Center" Name="napis"/>
        <Button Name="controllBtn" Content="Rozpocznij grę" FontSize="40" HorizontalAlignment="Center" Padding="10" Margin="0,5,0,0" Click="StartGame"/>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="25" Name="grid" Background="Black">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="122"/>
                <ColumnDefinition Width="122"/>
                <ColumnDefinition Width="122"/>
                <ColumnDefinition Width="122"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="122"/>
                <RowDefinition Height="122"/>
                <RowDefinition Height="122"/>
                <RowDefinition Height="122"/>
            </Grid.RowDefinitions>
        </Grid>
    </StackPanel>
</Window>
